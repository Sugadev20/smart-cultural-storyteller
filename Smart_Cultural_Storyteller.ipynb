def generate_prompt(age, language, moral):
    prompt = f"""
You are a traditional Indian storyteller.

Create a short cultural story for a child aged {age}.
Language: {language}

The story should:
- Be age-appropriate and simple to understand
- Be inspired by Indian culture (Panchatantra, Jataka Tales, folklore)
- Clearly teach the moral value: {moral}
- Have a positive and child-friendly ending

End the story with:
1. A clear explanation of the moral
2. One reflective question for the child
"""
    return prompt
# Example usage of the prompt generator

age = 8
language = "English"
moral = "Honesty"

story_prompt = generate_prompt(age, language, moral)
print(story_prompt)
def generate_story_from_llm(prompt):
    """
    This function simulates the response of a Large Language Model.
    In a real-world system, this would be replaced with an actual LLM API call.
    """
    
    story = """
Once upon a time in a small village in India, there lived a young boy named Arun.
Arun was known for his cleverness, but he sometimes chose easy shortcuts instead of telling the truth.

One day, Arun found a purse filled with coins near the village temple.
He thought about keeping it, but his heart reminded him of the importance of honesty.
Arun decided to take the purse to the village elder.

The elder smiled and praised Arun for his honesty.
The villagers respected Arun even more, and he felt proud of doing the right thing.

Moral of the Story:
