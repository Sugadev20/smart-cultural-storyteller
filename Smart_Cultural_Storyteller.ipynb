def generate_prompt(age, language, moral):
    prompt = f"""
You are a traditional Indian storyteller.

Create a short cultural story for a child aged {age}.
Language: {language}

The story should:
- Be age-appropriate and simple to understand
- Be inspired by Indian culture (Panchatantra, Jataka Tales, folklore)
- Clearly teach the moral value: {moral}
- Have a positive and child-friendly ending

End the story with:
1. A clear explanation of the moral
2. One reflective question for the child
"""
    return prompt
# Example usage of the prompt generator

age = 8
language = "English"
moral = "Honesty"

story_prompt = generate_prompt(age, language, moral)
print(story_prompt)
def generate_story_from_llm(prompt):
    """
